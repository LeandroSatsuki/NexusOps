# NexusOps
NODE_ENV=development
APP_NAME=NexusOps
APP_URL=http://localhost:3000
API_URL=http://localhost:3333

# Banco
POSTGRES_USER=nexusops
POSTGRES_PASSWORD=nexusops_dev_password
POSTGRES_DB=nexusops
DATABASE_URL=postgresql://nexusops:nexusops_dev_password@localhost:5432/nexusops?schema=public

# Cache preparado para evolucao
REDIS_URL=redis://localhost:6379

# API
API_PORT=3333
JWT_ACCESS_SECRET=change-me-access-secret-with-32-plus-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-with-32-plus-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=14
PASSWORD_RESET_TTL_MINUTES=30
AGENT_SHARED_TOKEN=change-me-agent-bootstrap-token
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=20
UPLOAD_DRIVER=local
UPLOAD_DIR=uploads

# Web
NEXT_PUBLIC_APP_NAME=NexusOps
NEXT_PUBLIC_API_URL=http://localhost:3333

# Agente Windows
NEXUSOPS_AGENT_API_URL=http://localhost:3333
NEXUSOPS_AGENT_TOKEN=change-me-agent-bootstrap-token
NEXUSOPS_AGENT_INTERVAL_SECONDS=60

